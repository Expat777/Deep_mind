# --- База данных ---
DATABASE_URL=postgresql+psycopg2://datamind:datamind@localhost:5432/datamind

# --- LLM (DeepSeek, OpenAI-совместимый API) ---
DEEPSEEK_API_KEY=pza_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://polza.ai/api/v1
DEEPSEEK_MODEL=deepseek/deepseek-chat

# --- LangSmith (трейсинг + Studio, опционально) ---
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=datamind

# --- Selectel Object Storage (S3) ---
SELECTEL_ENDPOINT=https://s3.ru-7.storage.selcloud.ru
SELECTEL_REGION=ru-7
SELECTEL_ACCESS_KEY=
SELECTEL_SECRET_KEY=
SELECTEL_BUCKET=datamind-files
