# --- База данных ---
DATABASE_URL=postgresql+psycopg2://datamind:datamind@localhost:5432/datamind

# --- LLM (DeepSeek, OpenAI-совместимый API) ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Selectel Object Storage (S3) ---
# Региональный эндпоинт Selectel (по умолчанию регион ru-1).
SELECTEL_ENDPOINT=https://s3.ru-1.storage.selcloud.ru
SELECTEL_REGION=ru-1
SELECTEL_ACCESS_KEY=
SELECTEL_SECRET_KEY=
SELECTEL_BUCKET=datamind-files
